# Google Drive upload (Option B — in-app Google sign-in)
# Copy this file to ".env" for local dev, and add the same two values as
# Environment Variables in your Vercel project (then redeploy).
#
# Both values are safe to expose in a client-side app:
#  - the OAuth Client ID is inherently public
#  - the API key should be restricted to your domains (HTTP referrers) in the
#    Google Cloud console
#
# Leave these unset and the app simply hides the "Drive" button (local
# CSV/JSON export still works).

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
